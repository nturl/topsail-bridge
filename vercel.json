{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "main": false
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "topsail.live" }],
      "destination": "https://topsailtraffic.com/:path*",
      "permanent": true
    }
  ]
}
